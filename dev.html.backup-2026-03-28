<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pickleball Court Tracker [DEV]</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #1a1a2e; color: #eee; min-height: 100vh; padding: 20px; }
  h1 { text-align: center; margin-bottom: 20px; color: #e94560; }
  #setup, #game { max-width: 800px; margin: 0 auto; }
  #game { display: none; }
  .setup-form { background: #16213e; padding: 20px; border-radius: 12px; }
  .setup-form label { display: block; margin-bottom: 6px; font-weight: 600; }
  .setup-form textarea { width: 100%; height: 120px; padding: 10px; border-radius: 8px; border: none; font-size: 14px; background: #0f3460; color: #eee; resize: vertical; }
  .setup-form small { color: #aaa; }
  button { background: #e94560; color: #fff; border: none; padding: 10px 24px; border-radius: 8px; cursor: pointer; font-size: 14px; font-weight: 600; margin-top: 12px; }
  button:hover { background: #c73650; }
  .court { background: #16213e; border-radius: 12px; padding: 16px; margin-bottom: 20px; }
  .court h2 { color: #e94560; margin-bottom: 12px; font-size: 18px; }
  .matchups { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; }
  .match { background: #0f3460; border-radius: 8px; padding: 12px; flex: 1; min-width: 200px; }
  .match .vs { text-align: center; color: #e94560; font-weight: 700; margin: 4px 0; }
  .match .team { display: flex; justify-content: space-between; align-items: center; padding: 4px 0; }
  .match .team .seed { color: #aaa; font-size: 12px; margin-right: 8px; }
  .match .team .name { font-weight: 600; font-size: 16px; }
  .match button { width: 100%; margin-top: 8px; padding: 8px; font-size: 13px; }
  .players-list { display: flex; gap: 8px; flex-wrap: wrap; }
  .players-list .player { background: #0f3460; padding: 6px 12px; border-radius: 6px; font-size: 13px; }
  .player .seed-num { color: #e94560; font-weight: 700; margin-right: 4px; }
  .player .consec { color: #ff6b6b; font-size: 11px; margin-left: 4px; }
  .round-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .round-header h2 { color: #e94560; }
  #history { max-width: 800px; margin: 20px auto 0; }
  #history h2 { color: #e94560; margin-bottom: 10px; }
  .history-entry { background: #16213e; padding: 10px 14px; border-radius: 8px; margin-bottom: 6px; font-size: 13px; color: #ccc; }
  .sync-status { text-align: center; font-size: 12px; color: #4ecca3; margin-bottom: 10px; }
  #lock { display: flex; justify-content: center; align-items: center; min-height: 60vh; }
  #lock .lock-box { background: #16213e; padding: 30px; border-radius: 12px; text-align: center; }
  #lock input { padding: 10px; border-radius: 8px; border: none; background: #0f3460; color: #eee; font-size: 16px; text-align: center; width: 200px; margin-top: 10px; }
  #lock .error { color: #ff6b6b; font-size: 13px; margin-top: 8px; }
  #app { display: none; }
  .player-row { display: flex; align-items: center; gap: 6px; padding: 6px 8px; margin: 4px 0; background: #0f3460; border-radius: 8px; }
  .player-row .seed-label { color: #e94560; font-weight: 700; min-width: 28px; }
  .player-row input.name-input { flex: 1; padding: 6px; border-radius: 6px; border: none; background: #16213e; color: #eee; font-size: 14px; }
  .player-row input.dupr-input { width: 50px; padding: 6px; border-radius: 6px; border: none; background: #16213e; color: #4ecca3; font-size: 13px; text-align: center; }
  .player-row .move-btn { background: none; border: none; color: #4ecca3; cursor: pointer; font-size: 18px; padding: 0 2px; margin: 0; line-height: 1; }
  .player-row .move-btn:hover { color: #e94560; }
  .player-row .remove-btn { background: none; border: none; color: #ff6b6b; cursor: pointer; font-size: 16px; padding: 0 4px; margin: 0; }
  .dupr-badge { color: #4ecca3; font-size: 11px; margin-left: 4px; }
</style>
</head>
<body>

<h1>🏓 Pickleball Court Tracker <span style="color:#ff6b6b;font-size:14px;vertical-align:super">DEV</span></h1>

<div id="lock">
  <div class="lock-box">
    <label style="font-weight:600;font-size:16px">🔒 Enter Passcode</label><br>
    <input type="password" id="passcodeInput" placeholder="Passcode" onkeydown="if(event.key==='Enter')checkPasscode()">
    <br><button onclick="checkPasscode()">Enter</button>
    <div class="error" id="lockError"></div>
  </div>
</div>

<div id="app">
<div class="sync-status" id="syncStatus">🔄 Select or create a session</div>

<div id="sessionPicker" style="margin-bottom:12px">
  <div style="display:flex;gap:8px;margin-bottom:10px">
    <button onclick="document.getElementById('newSessionForm').style.display='block';document.getElementById('sessionList').style.display='none'" style="flex:1;padding:10px;background:#4ecca3;color:#1a1a2e;font-weight:700">➕ New Session</button>
    <button onclick="loadSessionList();document.getElementById('newSessionForm').style.display='none'" style="flex:1;padding:10px;background:#0f3460">📋 Join Session</button>
  </div>
  <div id="newSessionForm" style="display:none;background:#0f3460;padding:12px;border-radius:8px;margin-bottom:8px">
    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
      <input id="sessionDate" type="date" style="padding:8px;border-radius:8px;border:none;background:#16213e;color:#eee;font-size:14px">
      <input id="locationInput" placeholder="Group name (optional)" onkeydown="if(event.key==='Enter')switchLocation()" style="padding:8px;border-radius:8px;border:none;background:#16213e;color:#eee;font-size:14px;flex:1">
      <button onclick="switchLocation()" style="margin:0;padding:8px 16px">Start</button>
    </div>
  </div>
  <div id="sessionList" style="display:none;background:#0f3460;padding:12px;border-radius:8px">
    <div id="sessionListItems" style="max-height:250px;overflow-y:auto"></div>
    <div id="noSessions" style="display:none;color:#aaa;padding:8px">No active sessions found.</div>
  </div>
  <span id="locationLabel" style="color:#4ecca3;font-size:13px"></span>
</div>

<div id="setup">
  <div class="setup-form">
    <label>Load players from schedule:</label>
    <select id="dateSelect" onchange="onDateSelect()" style="width:100%;padding:8px;border-radius:8px;border:none;background:#0f3460;color:#eee;font-size:14px;margin-bottom:12px">
      <option value="">-- Select a date --</option>
    </select>
    <button onclick="fetchSchedule()" style="background:#0f3460;margin-bottom:12px">🔄 Refresh Schedule</button>
    <label>Number of Courts:</label>
    <input type="number" id="numCourts" min="1" value="2" onchange="updateDummyNames()" oninput="updateDummyNames()" style="width:80px;padding:8px;border-radius:8px;border:none;background:#0f3460;color:#eee;font-size:14px;margin-bottom:12px">
    <label>Players (drag to reorder, edit if needed):</label>
    <small>First player = Seed 1 (best). Total players must equal courts × 4.</small>
    <div id="playerList" style="margin-bottom:12px"></div>
    <button onclick="addPlayerRow()" style="background:#0f3460;margin-bottom:8px">+ Add Player</button>
    <button onclick="sortByDupr()" style="background:#0f3460;margin-bottom:8px">📊 Sort by DUPR</button>
    <button onclick="showDuprLogin()" style="background:#0f3460;margin-bottom:8px">🔍 Fetch DUPR Ratings</button>
    <div id="duprModal" style="display:none;background:#0f3460;padding:16px;border-radius:8px;margin-bottom:12px">
      <label style="font-size:13px">Enter your DUPR login to fetch ratings for all players:</label>
      <div style="display:flex;gap:8px;margin-top:8px">
        <input id="duprEmail" placeholder="DUPR Email" style="flex:1;padding:8px;border-radius:6px;border:none;background:#16213e;color:#eee;font-size:13px">
        <input id="duprPass" type="password" placeholder="Password" style="flex:1;padding:8px;border-radius:6px;border:none;background:#16213e;color:#eee;font-size:13px">
        <button onclick="fetchDuprRatings()" style="margin:0;padding:8px 16px">Fetch</button>
        <button onclick="document.getElementById('duprModal').style.display='none'" style="margin:0;background:#16213e;padding:8px">✕</button>
      </div>
      <div id="duprStatus" style="font-size:12px;margin-top:6px;color:#aaa;white-space:pre-wrap;max-height:300px;overflow-y:auto"></div>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:8px">
      <button onclick="startGame()" style="flex:1">▶ Start Classic</button>
      <button onclick="startGame(true)" style="flex:1;background:#4ecca3;color:#1a1a2e;font-weight:700">📈 Start with DUPR Sim</button>
    </div>
    <button onclick="startRoundRobin()" style="background:#4ecca3;color:#1a1a2e">🔄 Round Robin</button>
    <button onclick="showPastSessions()" style="background:#0f3460">📜 Past Sessions</button>
  </div>
</div>

<div id="pastSessions" style="display:none;max-width:800px;margin:20px auto;">
  <h2 style="color:#e94560;margin-bottom:12px">📜 Past Sessions</h2>
  <div id="pastList"></div>
  <button onclick="document.getElementById('pastSessions').style.display='none'" style="margin-top:10px">← Back</button>
</div>

<div id="game">
  <div class="round-header">
    <h2>Round <span id="roundNum">1</span></h2>
    <div>
      <span id="sessionInfo" style="font-size:12px;color:#aaa;margin-right:12px"></span>
      <span id="sessionTimer" onclick="startSessionTimer()" style="font-size:16px;color:#4ecca3;margin-right:6px;font-weight:600;cursor:pointer;background:#0f3460;padding:8px 16px;border-radius:8px" title="Click to set timer">⏱ Set Timer</span>
      <span id="stopTimerBtn" onclick="stopTimer()" style="display:none;font-size:20px;color:#fff;font-weight:700;cursor:pointer;background:#e94560;padding:10px 22px;border-radius:8px;margin-right:6px">⏹ STOP</span>
      <select id="chimeSelect" style="font-size:11px;background:#1a1a2e;color:#aaa;border:1px solid #333;border-radius:4px;padding:1px 2px;vertical-align:middle;margin-right:12px">
        <option value="ascending">🎵 Ascending</option>
        <option value="descending">🎵 Descending</option>
        <option value="doorbell">🔔 Doorbell</option>
        <option value="fanfare">🏆 Fanfare</option>
        <option value="ping">🔔 Ping</option>
        <option value="triple">🎵 Triple</option>
        <option value="siren">🚨 Siren</option>
        <option value="airhorn">📢 Air Horn</option>
        <option value="whistle">🏁 Whistle</option>
        <option value="alarm">⏰ Alarm</option>
        <option value="layered">🔊 Layered</option>
      </select>
      <button onclick="undoRound()" style="background:#0f3460">↩ Undo</button>
      <button onclick="resetGame()">Reset</button>
      <button onclick="endSession()" style="background:#e94560">🏁 End Session</button>
    </div>
  </div>
  <div id="courts"></div>
  <div id="duprSummary"></div>
</div>

<div id="history"></div>

<div id="rrGame" style="display:none;max-width:800px;margin:0 auto;">
  <div class="round-header">
    <h2>🔄 Round Robin — Round <span id="rrRoundNum">1</span> of <span id="rrTotalRounds">?</span></h2>
    <div>
      <span id="rrSessionInfo" style="font-size:12px;color:#aaa;margin-right:12px"></span>
      <button onclick="resetRR()">Reset</button>
    </div>
  </div>
  <div id="rrCourts"></div>
  <div id="rrStandings" style="margin-top:20px"></div>
  <div id="rrLog" style="margin-top:20px"></div>
</div>

</div><!-- end #app -->

<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-database-compat.js"></script>
<script>
// --- Passcode Protection ---
const PASSCODE = 'pickle2026';

function checkPasscode() {
  const input = document.getElementById('passcodeInput').value;
  if (input === PASSCODE) {
    sessionStorage.setItem('pb_auth', 'true');
    unlock();
  } else {
    document.getElementById('lockError').textContent = 'Wrong passcode. Try again.';
  }
}

function unlock() {
  document.getElementById('lock').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  initApp();
}

// Auto-unlock if already authenticated this session
if (sessionStorage.getItem('pb_auth') === 'true') {
  document.addEventListener('DOMContentLoaded', unlock);
}

// --- App ---
let state = { players: [], round: 1, history: [], pendingResults: {}, prevState: null };
let db;

function initApp() {
  const firebaseConfig = {
  apiKey: "AIzaSyD4C8latdB9eZxVRvk41t_YsZFVrUDFNHA",
  authDomain: "pickleball-tracker-2ce69.firebaseapp.com",
  databaseURL: "https://pickleball-tracker-2ce69-default-rtdb.firebaseio.com",
  projectId: "pickleball-tracker-2ce69",
  storageBucket: "pickleball-tracker-2ce69.firebasestorage.app",
  messagingSenderId: "899482641607",
  appId: "1:899482641607:web:b02e440285628554aa4ae2"
};
  firebase.initializeApp(firebaseConfig);
  let currentLocation = sessionStorage.getItem('pkLocation') || '';
  document.getElementById('sessionDate').value = new Date().toISOString().slice(0, 10);
  if (currentLocation) {
    const parts = currentLocation.split('|');
    if (parts.length === 2) { document.getElementById('sessionDate').value = parts[0]; document.getElementById('locationInput').value = parts[1]; }
    else document.getElementById('locationInput').value = currentLocation;
    document.getElementById('locationLabel').textContent = '✅ ' + currentLocation.replace('|', ' — ');
    db = firebase.database().ref('dev-' + currentLocation.toLowerCase().replace(/[^a-z0-9]/g, '') + '/game');
    initDbListener();
  }

  window.switchLocation = function(sessionKey) {
    let date, name;
    if (sessionKey) {
      const parts = sessionKey.split('|');
      date = parts[0]; name = parts[1] || '';
      document.getElementById('sessionDate').value = date;
      document.getElementById('locationInput').value = name;
    } else {
      date = document.getElementById('sessionDate').value;
      name = document.getElementById('locationInput').value.trim();
    }
    if (!date) return alert('Select a date.');
    currentLocation = name ? date + '|' + name : date;
    const key = currentLocation.toLowerCase().replace(/[^a-z0-9]/g, '');
    sessionStorage.setItem('pkLocation', currentLocation);
    document.getElementById('locationLabel').textContent = '🏷️ ' + date + (name ? ' — ' + name : '') + '  ';
    const changeBtn = document.createElement('a');
    changeBtn.textContent = '(change)';
    changeBtn.style.cssText = 'color:#e94560;cursor:pointer;font-size:12px';
    changeBtn.onclick = () => { sessionStorage.removeItem('pkLocation'); location.reload(); };
    document.getElementById('locationLabel').appendChild(changeBtn);
    document.getElementById('syncStatus').textContent = '🔄 Connecting to server...';
    document.getElementById('sessionPicker').querySelector('#newSessionForm').style.display = 'none';
    document.getElementById('sessionList').style.display = 'none';
    try { document.getElementById('sessionPicker').children[0].style.display = 'none'; } catch(e) {}
    if (db) { db.off(); db = null; }
    if (rrDb) { rrDb.off(); rrDb = null; }
    db = firebase.database().ref('dev-' + key + '/game');
    document.getElementById('setup').style.display = 'block';
    document.getElementById('game').style.display = 'none';
    initDbListener();
    listenRR();
  }

  // Load active sessions list
  window.loadSessionList = function() {
    document.getElementById('sessionList').style.display = 'block';
    document.getElementById('sessionListItems').innerHTML = '<div style="color:#aaa;padding:8px">Loading...</div>';
    document.getElementById('noSessions').style.display = 'none';
    // Use shallow REST query to avoid downloading all data
    fetch('https://pickleball-tracker-2ce69-default-rtdb.firebaseio.com/.json?shallow=true')
      .then(r => r.json())
      .then(keys => {
        if (!keys) { document.getElementById('sessionListItems').innerHTML = ''; document.getElementById('noSessions').style.display = 'block'; return; }
        const devKeys = Object.keys(keys).filter(k => k.startsWith('dev-'));
        if (!devKeys.length) { document.getElementById('sessionListItems').innerHTML = ''; document.getElementById('noSessions').style.display = 'block'; return; }
        // Fetch just the game node for each dev key
        const promises = devKeys.map(k =>
          firebase.database().ref(k + '/game').once('value').then(snap => ({ key: k.replace('dev-', ''), data: snap.val() }))
        );
        return Promise.all(promises);
      })
      .then(results => {
        if (!results) return;
        const items = document.getElementById('sessionListItems');
        const sessions = results.filter(r => r.data && r.data.players && r.data.players.length)
          .map(r => {
            const name = r.data.sessionName ? r.data.sessionDate + ' — ' + r.data.sessionName : (r.data.sessionDate || r.key);
            return { key: r.key, playerCount: r.data.players.length, round: r.data.round || 1, label: name };
          });
        if (!sessions.length) { items.innerHTML = ''; document.getElementById('noSessions').style.display = 'block'; return; }
        items.innerHTML = sessions.map(s =>
          `<div onclick="switchLocation('${s.key}')" style="padding:10px;margin:4px 0;background:#16213e;border-radius:6px;cursor:pointer;display:flex;justify-content:space-between">
          <span>🏓 ${s.label}</span><span style="color:#4ecca3">${s.playerCount} players · Round ${s.round}</span></div>`
        ).join('');
      })
      .catch(() => { document.getElementById('sessionListItems').innerHTML = ''; document.getElementById('noSessions').style.display = 'block'; });
  }
  if (!currentLocation) loadSessionList();

  function getArchivePath() { return 'dev-' + currentLocation.toLowerCase().replace(/[^a-z0-9]/g, '') + '/archive'; }
  window.getArchivePath = getArchivePath;
  function getRrPath() { return 'dev-' + currentLocation.toLowerCase().replace(/[^a-z0-9]/g, '') + '/rr'; }
  window.getRrPath = getRrPath;

  function initDbListener() {
  // Listen for real-time updates from Firebase
  db.on('value', (snapshot) => {
  const data = snapshot.val();
  if (data && data.players && data.players.length) {
    state = data;
    state.pendingResults = state.pendingResults || {};
    state.history = state.history || [];
    document.getElementById('setup').style.display = 'none';
    document.getElementById('game').style.display = 'block';
    render();
  } else {
    document.getElementById('setup').style.display = 'block';
    document.getElementById('game').style.display = 'none';
  }
  document.getElementById('syncStatus').textContent = '✅ Connected — live sync active';
  });
  }
  if (currentLocation) initDbListener();
  fetchSchedule();
  renderPlayerList(dummyNames.slice(0, 8));
  listenRR();
} // end initApp

function saveState() {
  if (!db) return;
  db.set(state).then(() => {
    document.getElementById('syncStatus').textContent = '✅ Synced — all devices see the same game';
  }).catch(() => {
    document.getElementById('syncStatus').textContent = '❌ Sync failed — check connection';
  });
}

function startGame(dupr) {
  if (!db) { switchLocation(); if (!db) return; }
  const names = getPlayerNames();
  const duprs = getPlayerDuprs();
  const numCourts = parseInt(document.getElementById('numCourts').value);
  const needed = numCourts * 4;
  if (!numCourts || numCourts < 1) return alert('Enter a valid number of courts.');
  if (names.length !== needed) return alert(`You need exactly ${needed} players for ${numCourts} courts. You entered ${names.length}.`);
  state.players = names.map((name, i) => ({ name, seed: i + 1, consecLosses: 0, dupr: duprs[i] || 0 }));
  state.duprMode = !!dupr;
  state.startingDuprs = state.duprMode ? Object.fromEntries(names.map((name, i) => [name, duprs[i] || 0])) : null;
  state.round = 1;
  state.history = [];
  state.pendingResults = {};
  state.sessionStart = new Date().toISOString();
  state.sessionDate = document.getElementById('dateSelect').value || document.getElementById('sessionDate').value || 'Custom Game';
  state.sessionName = document.getElementById('locationInput').value.trim() || '';
  state.isQuickGame = false;
  document.getElementById('setup').style.display = 'none';
  document.getElementById('game').style.display = 'block';
  saveState();
  render();
}

function resetGame() {
  if (!confirm('Reset the game for everyone?')) return;
  clearInterval(timerInterval); timerInterval = null;
  archiveAndClear();
}

function endSession() {
  if (!confirm('End this session and save to history?')) return;
  clearInterval(timerInterval); timerInterval = null;
  // Capture state before anything resets it
  const snap = JSON.parse(JSON.stringify(state));
  const path = getArchivePath();
  // Detach listener so db.remove doesn't trigger state reset
  if (db) db.off();
  let promise = Promise.resolve();
  if (snap.players && snap.players.length && !snap.isQuickGame) {
    const key = (snap.sessionDate || 'Custom') + '_' + (snap.sessionStart || new Date().toISOString()).replace(/[.#$/\[\]]/g, '_');
    promise = firebase.database().ref(path + '/' + key.replace(/[.#$/\[\]]/g, '_')).set({
      sessionDate: snap.sessionDate || 'Custom Game',
      sessionStart: snap.sessionStart,
      sessionEnd: new Date().toISOString(),
      players: snap.players,
      history: snap.history || [],
      rounds: snap.round - 1
    });
  }
  promise.then(() => {
    if (db) db.remove();
    sessionStorage.removeItem('pkLocation');
    location.reload();
  });
}

function archiveAndClear() {
  let promise = null;
  if (state.players && state.players.length && !state.isQuickGame) {
    const key = (state.sessionDate || 'Custom') + '_' + (state.sessionStart || new Date().toISOString()).replace(/[.#$/\[\]]/g, '_');
    const archRef = firebase.database().ref(getArchivePath() + '/' + key.replace(/[.#$/\[\]]/g, '_'));
    promise = archRef.set({
      sessionDate: state.sessionDate || 'Custom Game',
      sessionStart: state.sessionStart,
      sessionEnd: new Date().toISOString(),
      players: state.players,
      history: state.history || [],
      rounds: state.round - 1
    }).then(() => {
      // Clear game after archive is confirmed saved
      state = { players: [], round: 1, history: [], pendingResults: {}, prevState: null };
      if (db) db.remove();
    });
  } else {
    state = { players: [], round: 1, history: [], pendingResults: {}, prevState: null };
    if (db) db.remove();
  }
  document.getElementById('setup').style.display = 'block';
  document.getElementById('game').style.display = 'none';
  document.getElementById('history').innerHTML = '';
  return promise;
}

function getCourts() {
  const courts = [];
  for (let i = 0; i < state.players.length; i += 4) {
    courts.push(state.players.slice(i, i + 4));
  }
  return courts;
}

function fmtDupr(p) { return p.dupr ? ' <span class="dupr-badge">' + p.dupr.toFixed(1) + '</span>' : ''; }

// DUPR simulation: modified Elo with point-differential (performance vs expectation)
// When scores provided: uses actual vs expected point share for realistic DUPR-style updates
// K=0.08 per game, spread=1.5 maps 2-8 DUPR scale
function updateSimDupr(players, base, winIdxs, loseIdxs, wScore, lScore) {
  const K = 0.08;
  const wAvg = winIdxs.reduce((s, i) => s + (players[base + i].dupr || 3.5), 0) / 2;
  const lAvg = loseIdxs.reduce((s, i) => s + (players[base + i].dupr || 3.5), 0) / 2;
  const expectedWin = 1 / (1 + Math.pow(10, (lAvg - wAvg) / 1.5));
  let delta;
  if (wScore !== null && lScore !== null) {
    // Performance vs expectation: compare actual point share to expected
    const total = wScore + lScore || 1;
    const actualShare = wScore / total;                    // e.g. 11/18 = 0.611
    const expectedShare = 0.5 + (expectedWin - 0.5) * 0.6; // dampen to ~0.35-0.65 range
    delta = K * (actualShare - expectedShare);              // positive = outperformed
  } else {
    delta = K * (1 - expectedWin);
  }
  const changes = [];
  winIdxs.forEach(i => {
    const p = players[base + i];
    if (!p.dupr) return;
    const d = +Math.abs(delta).toFixed(3);
    p.dupr = Math.min(8, +(p.dupr + d).toFixed(3));
    changes.push({ name: p.name, change: '+' + d.toFixed(3) });
  });
  loseIdxs.forEach(i => {
    const p = players[base + i];
    if (!p.dupr) return;
    const d = +Math.abs(delta).toFixed(3);
    p.dupr = Math.max(2, +(p.dupr - d).toFixed(3));
    changes.push({ name: p.name, change: '-' + d.toFixed(3) });
  });
  return changes;
}

