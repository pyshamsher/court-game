// --- Round Robin Mode ---
let rrState = null;
let rrDb;

function initRRDb() {
  if (!rrDb) rrDb = firebase.database().ref(getRrPath());
}

function startRoundRobin() {
  const names = getPlayerNames().filter(Boolean);
  if (names.length < 4) return alert('Need at least 4 players for round robin.');
  const duprs = getPlayerDuprs();
  const numCourts = parseInt(document.getElementById('numCourts').value);
  const hasDupr = duprs.some(d => d > 0);

  let teams;
  if (hasDupr) {
    // Balanced pairing: sort by DUPR, pair strongest with weakest
    const sorted = names.map((_, i) => i).sort((a, b) => (duprs[b] || 0) - (duprs[a] || 0));
    teams = [];
    const half = Math.floor(sorted.length / 2);
    for (let i = 0; i < half; i++)
      teams.push([sorted[i], sorted[sorted.length - 1 - i]]);
    // If odd number, pair remaining with strongest unmatched
    if (sorted.length % 2) teams.push([sorted[half], sorted[0]]);
  } else {
    // All possible team pairings
    teams = [];
    for (let i = 0; i < names.length; i++)
      for (let j = i + 1; j < names.length; j++)
        teams.push([i, j]);
  }

  // Generate matchups: every team vs every other team (no player plays against themselves)
  const matchups = [];
  for (let a = 0; a < teams.length; a++)
    for (let b = a + 1; b < teams.length; b++) {
      const ta = teams[a], tb = teams[b];
      if (ta[0] !== tb[0] && ta[0] !== tb[1] && ta[1] !== tb[0] && ta[1] !== tb[1])
        matchups.push({ teamA: ta, teamB: tb });
    }

  // Schedule rounds: each round fills up to numCourts games, no player plays twice per round
  const rounds = [];
  const used = new Set();
  let pool = matchups.map((m, i) => i);
  while (pool.length) {
    const round = [];
    const busyPlayers = new Set();
    const remaining = [];
    for (const idx of pool) {
      const m = matchups[idx];
      const ps = [...m.teamA, ...m.teamB];
      if (round.length < numCourts && ps.every(p => !busyPlayers.has(p))) {
        round.push(idx);
        ps.forEach(p => busyPlayers.add(p));
      } else {
        remaining.push(idx);
      }
    }
    if (!round.length) break; // can't schedule more
    rounds.push(round);
    pool = remaining;
  }

  rrState = {
    players: names,
    duprs: duprs,
    matchups,
    rounds,
    currentRound: 0,
    results: {},
    log: []
  };

  initRRDb();
  document.getElementById('setup').style.display = 'none';
  document.getElementById('rrGame').style.display = 'block';
  saveRR();
  renderRR();
}

function saveRR() {
  initRRDb();
  rrDb.set(rrState);
}

function renderRR() {
  if (!rrState) return;
  const { players, matchups, rounds, currentRound, results } = rrState;

  if (currentRound >= rounds.length) {
    document.getElementById('rrRoundNum').textContent = 'Complete!';
    document.getElementById('rrTotalRounds').textContent = rounds.length;
    document.getElementById('rrCourts').innerHTML = '<div style="text-align:center;color:#4ecca3;font-size:18px;padding:20px">🏆 All rounds complete!</div>';
    renderRRStandings();
    renderRRLog();
    return;
  }

  document.getElementById('rrRoundNum').textContent = currentRound + 1;
  document.getElementById('rrTotalRounds').textContent = rounds.length;

  const roundMatchups = rounds[currentRound];
  let html = '';
  let allDone = true;

  roundMatchups.forEach((mi, ci) => {
    const m = matchups[mi];
    const tA = m.teamA.map(i => players[i]).join(' & ');
    const tB = m.teamB.map(i => players[i]).join(' & ');
    const res = results[mi];
    html += `<div class="court"><h2>Court ${ci + 1}</h2>`;
    html += `<div class="match">`;
    html += `<div class="team"><span class="name">${tA}</span></div>`;
    html += `<div class="vs">VS</div>`;
    html += `<div class="team"><span class="name">${tB}</span></div>`;
    if (res) {
      html += `<div style="text-align:center;color:#4ecca3;margin-top:8px;font-weight:600">🏆 ${res === 'A' ? tA : tB}</div>`;
      html += `<button onclick="clearRRResult(${mi})" style="background:#0f3460;margin-top:4px;font-size:12px">↩ Change</button>`;
    } else {
      allDone = false;
      html += `<button onclick="recordRRResult(${mi},'A')">🏆 ${tA} Win</button>`;
      html += `<button onclick="recordRRResult(${mi},'B')" style="background:#0f3460;margin-top:4px">🏆 ${tB} Win</button>`;
    }
    html += `</div></div>`;
  });

  if (allDone && roundMatchups.every(mi => results[mi])) {
    html += `<div style="text-align:center;margin-top:10px"><button onclick="advanceRRRound()">Next Round →</button></div>`;
  }

  document.getElementById('rrCourts').innerHTML = html;
  renderRRStandings();
  renderRRLog();
}

function recordRRResult(mi, winner) {
  rrState.results[mi] = winner;
  saveRR();
  renderRR();
}

function clearRRResult(mi) {
  delete rrState.results[mi];
  saveRR();
  renderRR();
}

function advanceRRRound() {
  const { players, matchups, rounds, currentRound, results } = rrState;
  let logEntry = `<strong>Round ${currentRound + 1}:</strong><br>`;
  rounds[currentRound].forEach(mi => {
    const m = matchups[mi];
    const tA = m.teamA.map(i => players[i]).join(' & ');
    const tB = m.teamB.map(i => players[i]).join(' & ');
    const winner = results[mi] === 'A' ? tA : tB;
    logEntry += `🏆 ${winner} beat ${results[mi] === 'A' ? tB : tA}<br>`;
  });
  rrState.log.push(logEntry);
  rrState.currentRound++;
  saveRR();
  renderRR();
}

function renderRRStandings() {
  const { players, duprs, matchups, results } = rrState;
  const stats = players.map((name, i) => ({ name, idx: i, dupr: (duprs && duprs[i]) || 0, wins: 0, losses: 0, played: 0 }));
  Object.entries(results).forEach(([mi, winner]) => {
    const m = matchups[parseInt(mi)];
    const winTeam = winner === 'A' ? m.teamA : m.teamB;
    const loseTeam = winner === 'A' ? m.teamB : m.teamA;
    winTeam.forEach(i => { stats[i].wins++; stats[i].played++; });
    loseTeam.forEach(i => { stats[i].losses++; stats[i].played++; });
  });
  stats.sort((a, b) => b.wins - a.wins || a.losses - b.losses);
  let html = '<h2 style="color:#e94560;margin-bottom:10px">📊 Standings</h2>';
  html += '<div style="background:#16213e;border-radius:8px;padding:12px">';
  stats.forEach((s, i) => {
    const pct = s.played ? Math.round(100 * s.wins / s.played) : 0;
    const duprTag = s.dupr ? ` <span class="dupr-badge">${s.dupr.toFixed(1)}</span>` : '';
    html += `<div style="display:flex;justify-content:space-between;padding:6px 8px;${i === 0 && s.wins > 0 ? 'color:#4ecca3;font-weight:700' : ''}">`;
    html += `<span>${i + 1}. ${s.name}${duprTag}</span>`;
    html += `<span>${s.wins}W - ${s.losses}L (${pct}%)</span></div>`;
  });
  html += '</div>';
  document.getElementById('rrStandings').innerHTML = html;
}

function renderRRLog() {
  if (!rrState.log.length) { document.getElementById('rrLog').innerHTML = ''; return; }
  let html = '<h2 style="color:#e94560;margin-bottom:10px">History</h2>';
  rrState.log.slice().reverse().forEach(h => {
    html += `<div class="history-entry">${h}</div>`;
  });
  document.getElementById('rrLog').innerHTML = html;
}

function resetRR() {
  if (!confirm('Reset round robin for everyone?')) return;
  rrState = null;
  initRRDb();
  rrDb.remove();
  document.getElementById('rrGame').style.display = 'none';
  document.getElementById('setup').style.display = 'block';
  document.getElementById('rrStandings').innerHTML = '';
  document.getElementById('rrLog').innerHTML = '';
}

// Listen for RR state from Firebase
function listenRR() {
  initRRDb();
  rrDb.on('value', snap => {
    const data = snap.val();
    if (data && data.players) {
      rrState = data;
      rrState.results = rrState.results || {};
      rrState.log = rrState.log || [];
      document.getElementById('setup').style.display = 'none';
      document.getElementById('game').style.display = 'none';
      document.getElementById('rrGame').style.display = 'block';
      renderRR();
    }
  });
}
</script>
</body>
</html>
