function resolveRound() {
  // Save snapshot for undo
  state.prevState = JSON.stringify({ players: state.players, round: state.round, history: state.history, pendingResults: state.pendingResults });
  const numCourts = state.players.length / 4;
  let roundLog = `<strong>Round ${state.round}:</strong><br>`;
  const moves = [];

  for (let ci = 0; ci < numCourts; ci++) {
    const r = state.pendingResults[ci];
    const w = r.winner || r;
    const base = ci * 4;
    const winners = w === 'A' ? [0, 3] : [1, 2];
    const losers = w === 'A' ? [1, 2] : [0, 3];
    winners.forEach(i => { state.players[base + i].consecLosses = 0; });
    losers.forEach(i => { state.players[base + i].consecLosses += 1; });
    const wNames = winners.map(i => state.players[base + i].name).join(' & ');
    const lNames = losers.map(i => state.players[base + i].name).join(' & ');
    const scoreStr = r.scoreA !== undefined ? ` (${r.scoreA}–${r.scoreB})` : '';
    roundLog += `Court ${ci + 1}: 🏆 ${wNames} beat ${lNames}${scoreStr}<br>`;
  }

  // Simulate DUPR rating changes
  let duprLog = [];
  const anyDupr = state.duprMode && state.players.some(p => p.dupr > 0);
  if (anyDupr) {
    for (let ci = 0; ci < numCourts; ci++) {
      const r = state.pendingResults[ci];
      const w = r.winner || r;
      const base = ci * 4;
      const winIdxs = w === 'A' ? [0, 3] : [1, 2];
      const loseIdxs = w === 'A' ? [1, 2] : [0, 3];
      const wScore = r.scoreA !== undefined ? (w === 'A' ? r.scoreA : r.scoreB) : null;
      const lScore = r.scoreA !== undefined ? (w === 'A' ? r.scoreB : r.scoreA) : null;
      duprLog = duprLog.concat(updateSimDupr(state.players, base, winIdxs, loseIdxs, wScore, lScore));
    }
  }

  const newCourts = [];
  for (let ci = 0; ci < numCourts; ci++) {
    const r = state.pendingResults[ci];
    const w = r.winner || r;
    const base = ci * 4;
    const winIdxs = w === 'A' ? [0, 3] : [1, 2];
    const loseIdxs = w === 'A' ? [1, 2] : [0, 3];
    const winPlayers = winIdxs.map(i => state.players[base + i]);
    const losePlayers = loseIdxs.map(i => state.players[base + i]);
    newCourts.push([winPlayers[0], winPlayers[1], losePlayers[0], losePlayers[1]]);
  }

  for (let ci = 0; ci < numCourts - 1; ci++) {
    const dropper = newCourts[ci][3];
    const promoter = newCourts[ci + 1][0];
    moves.push(`⬇️ ${dropper.name} drops from Court ${ci+1} → Court ${ci+2} (Seed 1)`);
    moves.push(`⬆️ ${promoter.name} promotes from Court ${ci+2} → Court ${ci+1} (Seed 4)`);
    newCourts[ci + 1][0] = dropper;
    dropper.consecLosses = 0;
    newCourts[ci][3] = promoter;
    promoter.consecLosses = 0;
  }

  for (let ci = 0; ci < numCourts - 1; ci++) {
    const seed3 = newCourts[ci][2];
    if (seed3.consecLosses >= 2) {
      const promoter2 = newCourts[ci + 1][1];
      moves.push(`⬇️ ${seed3.name} (2 consecutive losses) drops from Court ${ci+1} → Court ${ci+2} (Seed 2)`);
      moves.push(`⬆️ ${promoter2.name} promotes from Court ${ci+2} → Court ${ci+1} (Seed 3)`);
      newCourts[ci + 1][1] = seed3;
      seed3.consecLosses = 0;
      newCourts[ci][2] = promoter2;
      promoter2.consecLosses = 0;
    }
  }

  if (moves.length) roundLog += `<br><em>Players rotated between courts.</em>`;
  else roundLog += `<br><em>No court changes this round.</em>`;

  if (duprLog.length) roundLog += `<br><strong>📈 DUPR Sim:</strong><br>` + duprLog.map(d => `&nbsp;&nbsp;${d.name}: ${d.change}`).join('<br>');

  state.players = newCourts.flat();
  state.history.push(roundLog);
  state.round++;
  state.pendingResults = {};
  saveState();
  render();
}

