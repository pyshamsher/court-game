const SCHEDULE_URL = 'https://docs.google.com/document/d/12111pYeuP-AgHln3_F2Fkha8jMoTxqInJQK-HX_r9ss/export?format=txt';
let scheduleData = {};

function fetchSchedule() {
  document.getElementById('dateSelect').innerHTML = '<option value="">Loading...</option>';
  fetch(SCHEDULE_URL)
    .then(r => r.text())
    .then(text => {
      scheduleData = {};
      // Find all date headers and their positions
      const datePattern = /(?:WED|FRI|MON|TUE|THU|SAT|SUN)\s+[A-Z]+\s+\d+/gi;
      const headers = [];
      let m;
      while ((m = datePattern.exec(text)) !== null) headers.push({ key: m[0].trim(), idx: m.index + m[0].length });

      // Extract numbered entries from a text chunk
      function extractPlayers(body) {
        const players = [];
        const re = /(\d+)\.\s*([^0-9?][^0-9]*?)(?=\s*\d+\.|$)/g;
        let pm;
        while ((pm = re.exec(body)) !== null) {
          const name = pm[2].trim().replace(/\.+$/, '');
          if (name && name !== '?') players.push(name);
        }
        // Last entry may have trailing waitlist names — cap to 2 words
        if (players.length) {
          const last = players[players.length - 1].split(/\s+/);
          if (last.length > 2) players[players.length - 1] = last.slice(0, 2).join(' ');
        }
        return players;
      }

      headers.forEach((h, i) => {
        const nextStart = i + 1 < headers.length ? headers[i + 1].idx - headers[i + 1].key.length : undefined;
        const body = text.substring(h.idx, nextStart);
        // Split body at every numbering restart (where "1." appears after a higher number)
        const chunks = [];
        const numRe = /(\d+)\.\s*/g;
        let nm, lastNum = 0, splitPoints = [];
        while ((nm = numRe.exec(body)) !== null) {
          const n = parseInt(nm[1]);
          if (n === 1 && lastNum > 1) splitPoints.push(nm.index);
          lastNum = n;
        }

        if (splitPoints.length > 0) {
          let prev = 0;
          splitPoints.forEach(sp => { chunks.push(body.substring(prev, sp)); prev = sp; });
          chunks.push(body.substring(prev));
          const emptyBefore = [];
          for (let j = i - 1; j >= 0 && !scheduleData[headers[j].key]; j--) emptyBefore.unshift(j);
          for (let c = 0; c < chunks.length - 1 && c < emptyBefore.length; c++) {
            const p = extractPlayers(chunks[c]);
            if (p.length) scheduleData[headers[emptyBefore[c]].key] = p;
          }
          const p = extractPlayers(chunks[chunks.length - 1]);
          if (p.length) scheduleData[h.key] = p;
        } else {
          const p = extractPlayers(body);
          if (p.length) scheduleData[h.key] = p;
        }
      });

      const sel = document.getElementById('dateSelect');
      sel.innerHTML = '<option value="">-- Select a date --</option>';
      Object.keys(scheduleData).forEach(d => {
        const opt = document.createElement('option');
        opt.value = d;
        opt.textContent = d + ' (' + scheduleData[d].length + ' players)';
        sel.appendChild(opt);
      });
    })
    .catch(() => {
      document.getElementById('dateSelect').innerHTML = '<option value="">Failed to load schedule</option>';
    });
}

