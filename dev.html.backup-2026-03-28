function fuzzyMatchPlayer(name, hits) {
  if (!hits.length) return null;
  const norm = s => s.toLowerCase().replace(/[^a-z]/g, '');
  const tokens = name.toLowerCase().split(/\s+/);
  const nameNorm = norm(name);

  let best = null, bestScore = 0;
  for (const h of hits) {
    if (!h.fullName) continue;
    const fn = h.fullName.toLowerCase();
    const fnNorm = norm(h.fullName);
    let score = 0;

    // Exact match
    if (fn === name.toLowerCase()) return h;

    // All tokens present in full name
    const tokensFound = tokens.filter(t => fn.includes(t)).length;
    score += tokensFound * 3;

    // Last name match (strongest signal)
    const hParts = fn.split(/\s+/);
    if (tokens.length > 1 && hParts.length > 1 && hParts[hParts.length - 1] === tokens[tokens.length - 1]) score += 5;

    // First name starts with same chars (Bob/Robert won't match, but partial like "Mike"/"Michael" gets a point)
    if (tokens[0] && hParts[0] && (hParts[0].startsWith(tokens[0]) || tokens[0].startsWith(hParts[0]))) score += 2;

    // Normalized containment
    if (fnNorm.includes(nameNorm) || nameNorm.includes(fnNorm)) score += 2;

    if (score > bestScore) { bestScore = score; best = h; }
  }
  // Require at least last name match or 2+ token matches to avoid false positives
  return bestScore >= 3 ? best : hits[0];
}

async function fetchDuprRatings() {
  const email = document.getElementById('duprEmail').value.trim();
  const pass = document.getElementById('duprPass').value;
  const status = document.getElementById('duprStatus');
  document.querySelectorAll('#duprPicker').forEach(el => el.remove());
  if (!email || !pass) return status.textContent = 'Enter email and password.';

  const names = getPlayerNames();
  if (!names.length) return status.textContent = 'Add players first.';

  status.textContent = '🔄 Logging in to DUPR...';
  status.style.color = '#aaa';

  try {
    // Login
    const loginRes = await fetch('https://api.dupr.gg/auth/v1.0/login/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password: pass })
    });
    const loginData = await loginRes.json();
    if (loginData.status !== 'SUCCESS') {
      status.style.color = '#ff6b6b';
      return status.textContent = '❌ Login failed: ' + (loginData.message || 'Invalid credentials');
    }
    const token = loginData.result.accessToken;

    // Get logged-in user's own profile for self-match
    let selfName = null, selfRatings = null;
    // Try login response user object
    const u = loginData.result.user;
    if (u) {
      selfName = u.fullName || u.name || ((u.firstName || '') + ' ' + (u.lastName || '')).trim();
      selfRatings = u.ratings;
      // If no ratings in user object, try fetching player profile
      if (!selfRatings && u.id) {
        try {
          const pRes = await fetch(`https://api.dupr.gg/player/v1.0/${u.id}`, {
            headers: { 'Authorization': 'Bearer ' + token }
          });
          const pData = await pRes.json();
          if (pData.result) { selfRatings = pData.result.ratings; }
        } catch (e) {}
      }
    }

    // Search each player
    const duprs = getPlayerDuprs();
    let found = 0;
    // Collect all search results first
    const allResults = [];
    for (let i = 0; i < names.length; i++) {
      status.textContent = `🔄 Looking up ${names[i]}... (${i+1}/${names.length})`;
      // Check if this player matches the logged-in user
      if (selfName && selfRatings) {
        const norm = s => s.toLowerCase().replace(/[^a-z]/g, '');
        if (norm(names[i]) === norm(selfName) || selfName.toLowerCase().includes(names[i].toLowerCase()) || names[i].toLowerCase().includes(selfName.toLowerCase())) {
          const rating = parseFloat(selfRatings.doubles) || parseFloat(selfRatings.singles) || 0;
          if (rating > 0) { duprs[i] = rating; found++; allResults.push({ idx: i, name: names[i], self: true }); continue; }
        }
      }
      try {
        const doSearch = async (q) => {
          const r = await fetch('https://api.dupr.gg/player/v1.0/search', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify({ query: q, limit: 10, offset: 0, filter: { lat: 51.05, lng: -114.07, radiusInMeters: 1000000 }, includeUnclaimedPlayers: false })
          });
          return r.json();
        };
        let searchData = await doSearch(names[i]);
        if (searchData.status === 'SUCCESS' && searchData.result && (!searchData.result.hits || !searchData.result.hits.length)) {
          const parts = names[i].trim().split(/\s+/);
          if (parts.length > 1) searchData = await doSearch(parts[parts.length - 1]);
        }
        const hits = (searchData.status === 'SUCCESS' && searchData.result && searchData.result.hits) || [];
        const autoMatch = hits.length ? fuzzyMatchPlayer(names[i], hits) : null;
        const autoRating = autoMatch?.ratings ? (parseFloat(autoMatch.ratings.doubles) || parseFloat(autoMatch.ratings.singles) || 0) : 0;
        if (autoRating > 0) { duprs[i] = autoRating; found++; }
        allResults.push({ idx: i, name: names[i], hits, autoMatch, autoRating });
      } catch (e) { allResults.push({ idx: i, name: names[i], hits: [], autoMatch: null, autoRating: 0, error: e.message }); }
    }

    // Auto-apply confident matches to player list immediately
    renderPlayerList(names, duprs);

    // Show interactive picker for review/correction
    status.style.color = '#4ecca3';
    status.innerHTML = `✅ Auto-filled ${found}/${names.length} players. Review & correct below:`;
    const pickerDiv = document.createElement('div');
    pickerDiv.id = 'duprPicker';
    pickerDiv.style.cssText = 'margin-top:8px;max-height:400px;overflow-y:auto';

    const buildSelect = (idx, hits, autoMatch) => {
      let html = `<select data-idx="${idx}" style="background:#16213e;color:#eee;border:1px solid #333;border-radius:4px;padding:4px;font-size:12px;min-width:200px">`;
      html += `<option value="">Skip (${hits.length} results)</option>`;
      hits.forEach(h => {
        const name = h.fullName || h.name || 'Unknown';
        const rating = h.ratings ? (parseFloat(h.ratings.doubles) || parseFloat(h.ratings.singles) || 0) : 0;
        const ratingStr = rating > 0 ? ` (${rating})` : ' (NR)';
        const selected = autoMatch && name === autoMatch.fullName ? ' selected' : '';
        html += `<option value="${rating}"${selected}>${name}${ratingStr}</option>`;
      });
      html += `</select>`;
      return html;
    };

    allResults.forEach(r => {
      const row = document.createElement('div');
      row.style.cssText = 'padding:6px 0;border-bottom:1px solid #1a1a2e;display:flex;align-items:center;gap:6px;flex-wrap:wrap';
      if (r.self) {
        row.innerHTML = `<span style="color:#4ecca3">✅ ${r.name} → self (${duprs[r.idx]})</span>`;
      } else {
        let html = `<span style="color:#aaa;min-width:90px">${r.name} (${r.hits.length} hits${r.error ? ', ERR: '+r.error : ''}) →</span>`;
        html += buildSelect(r.idx, r.hits, r.autoMatch);
        html += `<input data-ridx="${r.idx}" placeholder="Re-search name" style="width:120px;padding:4px;border-radius:4px;border:1px solid #333;background:#16213e;color:#eee;font-size:12px">`;
        html += `<button data-ridx="${r.idx}" style="padding:4px 8px;font-size:11px;margin:0;background:#0f3460">🔍</button>`;
        row.innerHTML = html;
        row.querySelector(`button[data-ridx="${r.idx}"]`).onclick = async function() {
          const input = row.querySelector(`input[data-ridx="${r.idx}"]`);
          const q = input.value.trim();
          if (!q) return;
          try {
            const sr = await fetch('https://api.dupr.gg/player/v1.0/search', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
              body: JSON.stringify({ query: q, limit: 10, offset: 0, filter: { lat: 51.05, lng: -114.07, radiusInMeters: 1000000 }, includeUnclaimedPlayers: false })
            });
            const sd = await sr.json();
            const newHits = (sd.status === 'SUCCESS' && sd.result && sd.result.hits) || [];
            const sel = row.querySelector(`select[data-idx="${r.idx}"]`);
            sel.outerHTML = buildSelect(r.idx, newHits, null);
          } catch (e) {}
        };
      }
      pickerDiv.appendChild(row);
    });
    const applyBtn = document.createElement('button');
    applyBtn.textContent = '✅ Apply Selections';
    applyBtn.style.cssText = 'margin-top:10px;padding:8px 16px';
    applyBtn.onclick = () => {
      pickerDiv.querySelectorAll('select').forEach(sel => {
        const idx = parseInt(sel.dataset.idx);
        const val = parseFloat(sel.value) || 0;
        if (val > 0) duprs[idx] = val;
      });
      let applied = duprs.filter(d => d > 0).length;
      const combined = names.map((n, i) => ({ n, d: duprs[i] }));
      combined.sort((a, b) => b.d - a.d);
      renderPlayerList(combined.map(p => p.n), combined.map(p => p.d));
      pickerDiv.querySelectorAll('[data-idx]').forEach(sel => {
        const idx = parseInt(sel.dataset.idx);
        if (duprs[idx] > 0) sel.closest('div').style.display = 'none';
      });
      const remaining = names.filter((_, i) => !duprs[i] || duprs[i] <= 0).length;
      if (remaining === 0) { pickerDiv.remove(); }
      status.style.color = '#4ecca3';
      status.textContent = remaining > 0
        ? `✅ Applied ${applied}/${names.length} ratings. ${remaining} still unmatched below:`
        : `✅ Applied DUPR ratings for ${applied}/${names.length} players (sorted by rating).`;
    };
    pickerDiv.appendChild(applyBtn);
    status.parentNode.insertBefore(pickerDiv, status.nextSibling);
    // Clear credentials from inputs
    document.getElementById('duprPass').value = '';
  } catch (e) {
    status.style.color = '#ff6b6b';
    status.textContent = '❌ Error: ' + e.message;
  }
}

